{
  "name": "eng-journal",
  "kind": "cross-agent-analytics-repo",
  "versioning": {
    "strategy": "semantic-release",
    "current_version": "0.0.0-semantically-released"
  },
  "primary_interface": "cli_plus_markdown",
  "analytics_core": "common_lisp",
  "ingestion_bridge": "python",
  "window_defaults": {
    "start_date": "2025-10-01",
    "end_date": "2026-03-31"
  },
  "data_sources": [
    "~/.claude/projects/**/*.jsonl",
    "~/.claude/history.jsonl",
    "~/Desktop/cc-config/logs/*.jsonl",
    "~/Desktop/cc-config/logs/.stats.json",
    "~/.codex/history.jsonl",
    "~/.codex/state_*.sqlite",
    "~/.codex/logs_*.sqlite"
  ],
  "source_discovery": {
    "env_overrides": [
      "ENG_JOURNAL_CLAUDE_DIR",
      "ENG_JOURNAL_CODEX_DIR",
      "ENG_JOURNAL_CC_CONFIG_DIR"
    ],
    "portable": true
  },
  "checkpointing": {
    "enabled": true,
    "verified_window": "2025-10-01_to_2026-03-31",
    "root": "checkpoints/"
  },
  "reports": [
    "review",
    "stats",
    "dashboard",
    "daily",
    "weekly",
    "prompts",
    "roi",
    "appraisal",
    "core-value"
  ],
  "valuation_policy": {
    "keep_roi_and_appraisal_separate": true,
    "roi_question": "Are Claude Code and Codex paying back subscription and compute-equivalent cost?",
    "appraisal_question": "What are the delivered artifacts and portfolio options plausibly worth under explicit scenario bands?",
    "appraisal_is_not_company_valuation": true
  },
  "latest_outputs": [
    "LEARNING.md",
    "checkpoints/2025-10-01_to_2026-03-31/manifest.json",
    "checkpoints/2025-10-01_to_2026-03-31/dataset.json",
    "reports/review-2025-10-01_to_2026-03-31.md",
    "reports/stats-2025-10-01_to_2026-03-31.md",
    "reports/stats-2025-10-01_to_2026-03-31.json",
    "reports/roi-2025-10-01_to_2026-03-31.md",
    "reports/prompts-claude_code-2025-10-01_to_2026-03-31.md",
    "reports/prompts-codex-2025-10-01_to_2026-03-31.md",
    "reports/dashboard-2025-10-01_to_2026-03-31.txt",
    "reports/dashboard-2026-02-12_to_2026-03-31.txt",
    "reports/daily-2026-03-31.md",
    "reports/weekly-2026-02-12_to_2026-03-31.md",
    "reports/prompts-codex-2026-02-12_to_2026-03-31.md",
    "reports/roi-2026-02-12_to_2026-03-31.md",
    "reports/appraisal-2026-02-12_to_2026-03-31.md",
    "reports/core-value-2026-02-12_to_2026-03-31.md",
    "assets/screenshots/dashboard-2026-02-12_to_2026-03-31.png",
    "assets/screenshots/core-value-2026-02-12_to_2026-03-31.png"
  ]
}
