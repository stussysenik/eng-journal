{
  "name": "eng-journal",
  "version": "0.0.0-semantically-released",
  "private": true,
  "description": "Cross-agent engineering journal and ROI analytics for Claude Code and Codex",
  "repository": {
    "type": "git",
    "url": "https://github.com/stussysenik/eng-journal.git"
  },
  "license": "MIT",
  "scripts": {
    "doctor": "./bin/journal doctor",
    "test": "python3 -m unittest discover -s tests",
