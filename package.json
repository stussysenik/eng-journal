    "stats:verified": "./bin/journal stats --start 2025-10-01 --end 2026-03-31 --format markdown",
    "report:dashboard": "./bin/journal report dashboard --start 2025-10-01 --end 2026-03-31",
    "report:impact": "./bin/journal report impact --start 2025-10-01 --end 2026-03-31",
    "report:roi": "./bin/journal report roi --start 2025-10-01 --end 2026-03-31",
    "report:appraisal": "./bin/journal report appraisal --start 2026-02-12 --end 2026-03-31",
    "report:core-value": "./bin/journal report core-value --start 2026-02-12 --end 2026-03-31",
    "capture:screenshots": "./bin/journal capture screenshots --start 2026-02-12 --end 2026-03-31",
    "release": "semantic-release"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.0",
    "semantic-release": "^24.0.0"
  }
